generator client {
  provider = "prisma-client"
  output   = "../packages/db/src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model HouseholdProfile {
  id               Int      @id
  taxYear          Int
  filingStatus     String
  hasDigitalAssets Boolean  @default(false)
  primaryTaxpayer  String
  stateResidence   String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model ImportedDocument {
  id             String        @id
  fileName       String
  storedFileName String
  fileSizeBytes  Int
  mimeType       String
  kind           String
  status         String
  taxYear        Int
  importedAt     DateTime
  extractedFields ExtractedField[]
  extractions    DocumentExtraction[]
  gaps           DataGap[]
  missingFacts   MissingFact[]
  questionnaireResponses QuestionnaireResponse[]
  assetLots      AssetLot[]

  @@index([importedAt])
  @@index([taxYear])
}

model MissingFact {
  id         String           @id
  documentId String
  sequence   Int
  key        String
  label      String
  reason     String
  severity   String
  document   ImportedDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@unique([documentId, sequence])
}

model AssetLot {
  id               String            @id
  accountName      String
  acquiredOn       String
  assetKind        String
  assetKey         String
  costBasisInCents Int
  displayName      String
  holdingTerm      String
  quantity         String
  sourceDocumentId String?
  sourceDocument   ImportedDocument? @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull)

  @@index([assetKey, acquiredOn])
  @@index([sourceDocumentId])
}

model DocumentExtraction {
  id            String           @id
  documentId    String
  extractorKey  String
  status        String
  statusMessage String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  parsedAt      DateTime?
  document      ImportedDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  fields        ExtractedField[]

  @@index([documentId])
  @@index([status])
}

model ExtractedField {
  id             String             @id
  extractionId   String
  documentId     String
  key            String
  label          String
  valueType      String
  rawValue       String
  normalizedValue String?
  confidence     String
  taxRelevance   String
  isMissing      Boolean            @default(false)
  sourcePage     Int?
  provenanceHint String?
  extraction     DocumentExtraction @relation(fields: [extractionId], references: [id], onDelete: Cascade)
  document       ImportedDocument   @relation(fields: [documentId], references: [id], onDelete: Cascade)
  gaps           DataGap[]

  @@index([documentId])
  @@index([extractionId])
}

model DataGap {
  id              String          @id
  documentId      String?
  extractedFieldId String?
  gapKind         String
  key             String
  title           String
  description     String
  severity        String
  status          String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  document        ImportedDocument? @relation(fields: [documentId], references: [id], onDelete: Cascade)
  extractedField  ExtractedField? @relation(fields: [extractedFieldId], references: [id], onDelete: SetNull)
  questionnaireResponses QuestionnaireResponse[]

  @@index([documentId])
  @@index([extractedFieldId])
  @@index([status])
}

model QuestionnaireResponse {
  id              String           @id
  promptKey       String
  taxYear         Int
  value           String
  answeredAt      DateTime         @default(now())
  sourceDocumentId String?
  sourceGapId     String?
  sourceDocument  ImportedDocument? @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull)
  sourceGap       DataGap?         @relation(fields: [sourceGapId], references: [id], onDelete: SetNull)

  @@index([promptKey, taxYear])
  @@index([sourceDocumentId])
  @@index([sourceGapId])
}

model PlanWorkItem {
  id                    String                    @id
  sequence              Int                       @unique
  projectId             String
  title                 String
  summary               String
  kind                  String
  priority              String
  status                String
  targetIteration       String?
  owner                 String?
  auditWorkflowRunId    String?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  acceptanceCriteria    PlanAcceptanceCriterion[]
  blockedByDependencies WorkItemDependency[]      @relation("BlockedWorkItem")
  blockingDependencies  WorkItemDependency[]      @relation("BlockingWorkItem")
  planRuns              PlanRun[]
  project               PlanProject               @relation(fields: [projectId], references: [id], onDelete: Restrict)
  tasks                 PlanWorkItemTask[]

  @@index([projectId])
  @@index([priority])
  @@index([status])
  @@index([updatedAt])
}

model PlanProject {
  id          String         @id
  key         String         @unique
  name        String
  description String?
  isActive    Boolean        @default(true)
  sortOrder   Int
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  workItems   PlanWorkItem[]

  @@index([isActive, sortOrder])
}

model PlanWorkItemTask {
  id         String       @id
  workItemId String
  sequence   Int
  title      String
  status     String
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  workItem   PlanWorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)

  @@index([workItemId])
  @@unique([workItemId, sequence])
}

model PlanAcceptanceCriterion {
  id         String       @id
  workItemId String
  sequence   Int
  title      String
  status     String
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  workItem   PlanWorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)

  @@index([workItemId])
  @@unique([workItemId, sequence])
}

model PlanRun {
  id                 String     @id
  workItemId         String
  mode               String
  status             String
  summary            String
  auditWorkflowRunId String?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  steps              PlanStep[]
  workItem           PlanWorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)

  @@index([workItemId])
  @@index([status])
}

model PlanStep {
  id        String   @id
  planRunId String
  sequence  Int
  phase     String
  title     String
  status    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  planRun   PlanRun  @relation(fields: [planRunId], references: [id], onDelete: Cascade)

  @@index([planRunId])
  @@unique([planRunId, sequence])
}

model WorkItemDependency {
  blockedWorkItemId  String
  blockingWorkItemId String
  createdAt          DateTime     @default(now())
  blockedWorkItem    PlanWorkItem @relation("BlockedWorkItem", fields: [blockedWorkItemId], references: [id], onDelete: Cascade)
  blockingWorkItem   PlanWorkItem @relation("BlockingWorkItem", fields: [blockingWorkItemId], references: [id], onDelete: Cascade)

  @@id([blockedWorkItemId, blockingWorkItemId])
  @@index([blockingWorkItemId])
}

model KnowledgeSubject {
  id             String           @id
  slug           String           @unique
  kind           String
  name           String
  namespace      String
  summary        String?
  profileJson    String?
  isPrimaryHuman Boolean          @default(false)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  entries        KnowledgeEntry[]

  @@index([kind, name])
  @@index([isPrimaryHuman, updatedAt])
  @@index([namespace])
}

model KnowledgeEntry {
  id            String           @id
  slug          String           @unique
  subjectId     String?
  namespace     String
  title         String
  kind          String
  visibility    String
  status        String
  importance    String
  origin        String
  createdByKind String
  createdByName String?
  tagsJson      String
  contentJson   String
  sourceTitle   String?
  sourceUri     String?
  sourceChecksum String?
  lastReviewedAt DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  subject       KnowledgeSubject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)

  @@index([subjectId, updatedAt])
  @@index([kind, updatedAt])
  @@index([namespace, updatedAt])
  @@index([status, updatedAt])
  @@index([visibility, updatedAt])
}

model AuditRun {
  id                   String                 @id
  workflow             String
  task                 String?
  actor                String
  agentName            String?
  planRunId            String?
  planStepId           String?
  project              String?
  sessionId            String?
  workItemId           String?
  status               String
  repoPath             String?
  worktreePath         String
  startedAt            DateTime
  completedAt          DateTime?
  durationMs           Int?
  executionCount       Int                    @default(0)
  failedExecutionCount Int                    @default(0)
  decisionCount        Int                    @default(0)
  artifactCount        Int                    @default(0)
  failureCount         Int                    @default(0)
  handoffCount         Int                    @default(0)
  latestEventAt        DateTime?
  statsByKindJson      String?
  statsByStatusJson    String?
  summaryJson          String?
  decisions            AuditDecisionRecord[]
  artifacts            AuditArtifactRecord[]
  failures             AuditFailureRecord[]
  handoffs             AuditHandoffRecord[]
  events               AuditEventRecord[]
  executions           AuditExecutionRecord[]

  @@index([workflow, startedAt])
  @@index([status, startedAt])
  @@index([project, startedAt])
  @@index([agentName, startedAt])
  @@index([workItemId, startedAt])
  @@index([planRunId, startedAt])
  @@index([planStepId, startedAt])
  @@index([worktreePath, startedAt])
  @@index([latestEventAt])
}

model AuditDecisionRecord {
  id           String                @id
  runId        String
  executionId  String?
  category     String
  summary      String
  rationale    String?
  selectedOption String?
  optionsJson  String?
  metadataJson String?
  timestamp    DateTime
  run          AuditRun              @relation(fields: [runId], references: [id], onDelete: Cascade)
  execution    AuditExecutionRecord? @relation(fields: [executionId], references: [id], onDelete: SetNull)

  @@index([runId, timestamp])
  @@index([category, timestamp])
  @@index([executionId, timestamp])
}

model AuditArtifactRecord {
  id           String                @id
  runId        String
  executionId  String?
  artifactType String
  label        String
  status       String
  path         String?
  uri          String?
  metadataJson String?
  timestamp    DateTime
  run          AuditRun              @relation(fields: [runId], references: [id], onDelete: Cascade)
  execution    AuditExecutionRecord? @relation(fields: [executionId], references: [id], onDelete: SetNull)

  @@index([runId, timestamp])
  @@index([artifactType, timestamp])
  @@index([executionId, timestamp])
}

model AuditFailureRecord {
  id           String                @id
  runId        String
  executionId  String?
  category     String
  severity     String
  status       String
  summary      String
  detail       String?
  retryable    Boolean               @default(false)
  metadataJson String?
  timestamp    DateTime
  run          AuditRun              @relation(fields: [runId], references: [id], onDelete: Cascade)
  execution    AuditExecutionRecord? @relation(fields: [executionId], references: [id], onDelete: SetNull)

  @@index([runId, timestamp])
  @@index([category, timestamp])
  @@index([severity, timestamp])
  @@index([executionId, timestamp])
}

model AuditHandoffRecord {
  id             String                @id
  runId          String
  executionId    String?
  workItemId     String?
  planRunId      String?
  planStepId     String?
  sourceAgent    String
  targetAgent    String
  status         String
  summary        String
  detail         String?
  artifactIdsJson String?
  metadataJson   String?
  timestamp      DateTime
  run            AuditRun              @relation(fields: [runId], references: [id], onDelete: Cascade)
  execution      AuditExecutionRecord? @relation(fields: [executionId], references: [id], onDelete: SetNull)

  @@index([runId, timestamp])
  @@index([workItemId, timestamp])
  @@index([planRunId, timestamp])
  @@index([planStepId, timestamp])
  @@index([sourceAgent, timestamp])
  @@index([targetAgent, timestamp])
  @@index([status, timestamp])
  @@index([executionId, timestamp])
}

model AuditExecutionRecord {
  id                String                 @id
  runId             String
  parentExecutionId String?
  kind              String
  name              String
  step              String?
  status            String
  startedAt         DateTime
  completedAt       DateTime?
  durationMs        Int?
  exitCode          Int?
  errorName         String?
  errorMessage      String?
  commandJson       String?
  metadataJson      String?
  logFile           String?
  run               AuditRun               @relation(fields: [runId], references: [id], onDelete: Cascade)
  parent            AuditExecutionRecord?  @relation("AuditExecutionHierarchy", fields: [parentExecutionId], references: [id], onDelete: SetNull)
  children          AuditExecutionRecord[] @relation("AuditExecutionHierarchy")
  decisions         AuditDecisionRecord[]
  artifacts         AuditArtifactRecord[]
  failures          AuditFailureRecord[]
  handoffs          AuditHandoffRecord[]
  events            AuditEventRecord[]

  @@index([runId, startedAt])
  @@index([kind, startedAt])
  @@index([status, startedAt])
  @@index([parentExecutionId])
}

model HeartbeatEvent {
  id         String   @id @default(cuid())
  runId      String
  workItemId String?
  message    String
  createdAt  DateTime @default(now())

  @@index([runId, createdAt])
  @@index([workItemId, createdAt])
}

model TranscriptArtifact {
  id         String   @id @default(cuid())
  runId      String   @unique
  workItemId String?
  filePath   String
  capturedAt DateTime @default(now())
  lineCount  Int?

  @@index([workItemId])
  @@index([capturedAt])
}

model AuditEventRecord {
  id                String                @id
  runId             String
  executionId       String?
  eventType         String
  actor             String
  agentName         String?
  cwd               String
  status            String?
  step              String?
  task              String?
  timestamp         DateTime
  durationMs        Int?
  exitCode          Int?
  errorName         String?
  errorMessage      String?
  logFile           String?
  commandJson       String?
  metadataJson      String?
  executionKind     String?
  executionName     String?
  planRunId         String?
  planStepId        String?
  parentExecutionId String?
  project           String?
  sessionId         String?
  workflow          String
  workItemId        String?
  run               AuditRun              @relation(fields: [runId], references: [id], onDelete: Cascade)
  execution         AuditExecutionRecord? @relation(fields: [executionId], references: [id], onDelete: SetNull)

  @@index([runId, timestamp])
  @@index([executionId, timestamp])
  @@index([timestamp])
  @@index([workflow, timestamp])
  @@index([workItemId, timestamp])
  @@index([planRunId, timestamp])
  @@index([planStepId, timestamp])
}

model WorkflowDefinition {
  id               String   @id @default(cuid())
  name             String
  version          String
  description      String?
  triggerEvents    String
  definitionJson   String
  status           String   @default("active")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([name])
  @@index([status])
}

model WorkflowRun {
  id               String   @id @default(cuid())
  definitionId     String
  definitionName   String
  version          String
  status           String   @default("pending")
  currentStep      String?
  contextJson      String?
  correlationId    String?
  parentRunId      String?
  startedAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  completedAt      DateTime?
  workflowStepRuns WorkflowStepRun[]

  @@index([definitionId])
  @@index([status])
  @@index([correlationId])
  @@index([parentRunId])
  @@index([startedAt])
}

model WorkflowStepRun {
  id               String   @id @default(cuid())
  runId            String
  stepId           String
  stepType         String
  nodeType         String
  agentId          String?
  model            String?
  skillIds         String?
  inputJson        String?
  outputJson       String?
  errorJson        String?
  retryCount       Int      @default(0)
  startedAt        DateTime @default(now())
  completedAt      DateTime?
  run              WorkflowRun @relation(fields: [runId], references: [id])

  @@index([runId])
  @@index([stepId])
  @@index([startedAt])
}

model WorkflowEvent {
  id               String   @id @default(cuid())
  type             String
  source           String
  correlationId    String?
  causationId      String?
  payload          String
  metadata         String?
  occurredAt       DateTime @default(now())
  processedAt      DateTime?

  @@index([type])
  @@index([source])
  @@index([correlationId])
  @@index([occurredAt])
}

model WorkflowApproval {
  id               String   @id @default(cuid())
  runId            String
  stepId           String
  status           String   @default("pending")
  prompt           String
  responseJson     String?
  requestedAt      DateTime @default(now())
  respondedAt      DateTime?

  @@index([runId])
  @@index([stepId])
  @@index([status])
}

model Agent {
  id               String   @id @default(cuid())
  name             String   @unique
  description      String?
  model            String
  tier             String
  providerFamily   String   @default("anthropic")
  runtimeKind      String   @default("claude-code-subagent")
  configSourcePath String?
  allowedSkillIds  String?
  version          String   @default("1.0.0")
  status           String   @default("active")
  metadata         String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([status])
  @@index([tier])
  @@index([providerFamily])
  @@index([runtimeKind])
}

model Skill {
  id               String   @id @default(cuid())
  name             String
  version          String
  description      String?
  category         String?
  inputSchema      String?
  outputSchema     String?
  executionMode    String   @default("agent")
  permissions      String?
  status           String   @default("active")
  createdAt        DateTime @default(now())

  @@unique([name, version])
  @@index([status])
  @@index([category])
}

model ExternalEventSource {
  id               String   @id @default(cuid())
  name             String   @unique
  type             String
  configJson       String?
  status           String   @default("active")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([status])
  @@index([type])
}

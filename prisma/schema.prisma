generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model HouseholdProfile {
  id               Int      @id
  taxYear          Int
  filingStatus     String
  hasDigitalAssets Boolean  @default(false)
  primaryTaxpayer  String
  stateResidence   String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model ImportedDocument {
  id             String        @id
  fileName       String
  storedFileName String
  fileSizeBytes  Int
  mimeType       String
  kind           String
  status         String
  taxYear        Int
  importedAt     DateTime
  extractedFields ExtractedField[]
  extractions    DocumentExtraction[]
  gaps           DataGap[]
  missingFacts   MissingFact[]
  questionnaireResponses QuestionnaireResponse[]
  assetLots      AssetLot[]

  @@index([importedAt])
  @@index([taxYear])
}

model MissingFact {
  id         String           @id
  documentId String
  sequence   Int
  key        String
  label      String
  reason     String
  severity   String
  document   ImportedDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@unique([documentId, sequence])
}

model AssetLot {
  id               String            @id
  accountName      String
  acquiredOn       String
  assetKind        String
  assetKey         String
  costBasisInCents Int
  displayName      String
  holdingTerm      String
  quantity         String
  sourceDocumentId String?
  sourceDocument   ImportedDocument? @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull)

  @@index([assetKey, acquiredOn])
  @@index([sourceDocumentId])
}

model DocumentExtraction {
  id            String           @id
  documentId    String
  extractorKey  String
  status        String
  statusMessage String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  parsedAt      DateTime?
  document      ImportedDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  fields        ExtractedField[]

  @@index([documentId])
  @@index([status])
}

model ExtractedField {
  id             String             @id
  extractionId   String
  documentId     String
  key            String
  label          String
  valueType      String
  rawValue       String
  normalizedValue String?
  confidence     String
  taxRelevance   String
  isMissing      Boolean            @default(false)
  sourcePage     Int?
  provenanceHint String?
  extraction     DocumentExtraction @relation(fields: [extractionId], references: [id], onDelete: Cascade)
  document       ImportedDocument   @relation(fields: [documentId], references: [id], onDelete: Cascade)
  gaps           DataGap[]

  @@index([documentId])
  @@index([extractionId])
}

model DataGap {
  id              String          @id
  documentId      String?
  extractedFieldId String?
  gapKind         String
  key             String
  title           String
  description     String
  severity        String
  status          String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  document        ImportedDocument? @relation(fields: [documentId], references: [id], onDelete: Cascade)
  extractedField  ExtractedField? @relation(fields: [extractedFieldId], references: [id], onDelete: SetNull)
  questionnaireResponses QuestionnaireResponse[]

  @@index([documentId])
  @@index([extractedFieldId])
  @@index([status])
}

model QuestionnaireResponse {
  id              String           @id
  promptKey       String
  taxYear         Int
  value           String
  answeredAt      DateTime         @default(now())
  sourceDocumentId String?
  sourceGapId     String?
  sourceDocument  ImportedDocument? @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull)
  sourceGap       DataGap?         @relation(fields: [sourceGapId], references: [id], onDelete: SetNull)

  @@index([promptKey, taxYear])
  @@index([sourceDocumentId])
  @@index([sourceGapId])
}

model PlanWorkItem {
  id                    String                    @id
  sequence              Int                       @unique
  title                 String
  summary               String
  kind                  String
  priority              String
  status                String
  targetIteration       String?
  owner                 String?
  auditWorkflowRunId    String?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  acceptanceCriteria    PlanAcceptanceCriterion[]
  blockedByDependencies WorkItemDependency[]      @relation("BlockedWorkItem")
  blockingDependencies  WorkItemDependency[]      @relation("BlockingWorkItem")
  planRuns              PlanRun[]
  tasks                 PlanWorkItemTask[]

  @@index([priority])
  @@index([status])
  @@index([updatedAt])
}

model PlanWorkItemTask {
  id         String       @id
  workItemId String
  sequence   Int
  title      String
  status     String
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  workItem   PlanWorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)

  @@index([workItemId])
  @@unique([workItemId, sequence])
}

model PlanAcceptanceCriterion {
  id         String       @id
  workItemId String
  sequence   Int
  title      String
  status     String
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  workItem   PlanWorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)

  @@index([workItemId])
  @@unique([workItemId, sequence])
}

model PlanRun {
  id                 String     @id
  workItemId         String
  mode               String
  status             String
  summary            String
  auditWorkflowRunId String?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  steps              PlanStep[]
  workItem           PlanWorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)

  @@index([workItemId])
  @@index([status])
}

model PlanStep {
  id        String   @id
  planRunId String
  sequence  Int
  phase     String
  title     String
  status    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  planRun   PlanRun  @relation(fields: [planRunId], references: [id], onDelete: Cascade)

  @@index([planRunId])
  @@unique([planRunId, sequence])
}

model WorkItemDependency {
  blockedWorkItemId  String
  blockingWorkItemId String
  createdAt          DateTime     @default(now())
  blockedWorkItem    PlanWorkItem @relation("BlockedWorkItem", fields: [blockedWorkItemId], references: [id], onDelete: Cascade)
  blockingWorkItem   PlanWorkItem @relation("BlockingWorkItem", fields: [blockingWorkItemId], references: [id], onDelete: Cascade)

  @@id([blockedWorkItemId, blockingWorkItemId])
  @@index([blockingWorkItemId])
}

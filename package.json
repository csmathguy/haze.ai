{
  "name": "taxes",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.9.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/csmathguy/Taxes.git"
  },
  "bugs": {
    "url": "https://github.com/csmathguy/Taxes/issues"
  },
  "homepage": "https://github.com/csmathguy/Taxes#readme",
  "engines": {
    "node": ">=24.14.0",
    "npm": ">=11.6.4"
  },
  "workspaces": [
    "apps/*",
    "apps/*/*",
    "packages/*"
  ],
  "scripts": {
    "build:audit:web": "node tools/runtime/run-npm.cjs run build -w @taxes/audit-web",
    "build:web": "node tools/runtime/run-npm.cjs run build -w @taxes/web",
    "dev:audit:api": "node tools/runtime/run-npm.cjs run dev -w @taxes/audit-api",
    "dev:audit:web": "node tools/runtime/run-npm.cjs run dev -w @taxes/audit-web",
    "dev:api": "node tools/runtime/run-npm.cjs run dev -w @taxes/api",
    "dev:web": "node tools/runtime/run-npm.cjs run dev -w @taxes/web",
    "prisma:check": "npm run prisma:validate && npm run prisma:generate",
    "prisma:generate": "tsx tools/database/generate-client.ts",
    "prisma:migrate:deploy": "tsx tools/database/apply-migrations.ts",
    "prisma:migrate:dev": "tsx tools/database/create-migration.ts",
    "prisma:studio": "prisma studio --schema prisma/schema.prisma",
    "pr:draft": "tsx tools/agent/pull-request-draft.ts",
    "pr:sync": "tsx tools/agent/pull-request-sync.ts",
    "prisma:validate": "prisma validate --schema prisma/schema.prisma",
    "prepare": "simple-git-hooks",
    "lint": "eslint apps/api/src apps/web/src apps/web/vite.config.ts apps/audit/api/src apps/audit/web/src apps/audit/web/vite.config.ts packages/shared/src prisma.config.ts tools/agent tools/database tools/quality vitest.config.ts --max-warnings=0",
    "lint:fix": "eslint apps/api/src apps/web/src apps/web/vite.config.ts apps/audit/api/src apps/audit/web/src apps/audit/web/vite.config.ts packages/shared/src prisma.config.ts tools/agent tools/database tools/quality vitest.config.ts --fix",
    "stylelint": "stylelint \"apps/web/src/**/*.{css,scss}\" \"apps/audit/web/src/**/*.{css,scss}\" --allow-empty-input",
    "stylelint:fix": "stylelint \"apps/web/src/**/*.{css,scss}\" \"apps/audit/web/src/**/*.{css,scss}\" --fix --allow-empty-input",
    "typecheck": "npm run typecheck:shared && npm run typecheck:api && npm run typecheck:web && npm run typecheck:audit:api && npm run typecheck:audit:web && npm run typecheck:quality",
    "typecheck:api": "tsc --noEmit -p apps/api/tsconfig.json",
    "typecheck:audit:api": "tsc --noEmit -p apps/audit/api/tsconfig.json",
    "typecheck:audit:web": "tsc --noEmit -p apps/audit/web/tsconfig.json",
    "typecheck:shared": "tsc --noEmit -p packages/shared/tsconfig.json",
    "typecheck:web": "tsc --noEmit -p apps/web/tsconfig.json",
    "typecheck:quality": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:arch": "vitest run tools/quality/architecture",
    "quality": "npm run prisma:check && npm run typecheck && npm run lint && npm run stylelint && npm run test",
    "quality:changed": "tsx tools/agent/changed-quality.ts",
    "quality:changed:staged": "tsx tools/agent/changed-quality.ts --staged --workflow pre-commit",
    "quality:logged": "tsx tools/agent/quality-gates.ts",
    "quality:logged:coverage": "tsx tools/agent/quality-gates.ts --with-coverage",
    "agent:worktree:create": "tsx tools/agent/parallel-worktree.ts",
    "workflow:retro": "tsx tools/agent/retrospective.ts",
    "execution:start": "tsx tools/agent/execution-log.ts start",
    "execution:end": "tsx tools/agent/execution-log.ts end",
    "workflow:start": "tsx tools/agent/workflow-log.ts start",
    "workflow:note": "tsx tools/agent/workflow-log.ts note",
    "workflow:end": "tsx tools/agent/workflow-log.ts end"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.4.0",
    "@vitest/coverage-v8": "^4.0.18",
    "archunit": "^2.1.63",
    "dotenv": "^17.3.1",
    "eslint": "^10.0.3",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.0.2",
    "globals": "^17.4.0",
    "prisma": "^7.4.2",
    "simple-git-hooks": "^2.13.1",
    "stylelint": "^17.4.0",
    "stylelint-config-standard": "^40.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.0.18"
  },
  "simple-git-hooks": {
    "pre-commit": "node tools/runtime/run-npm.cjs run quality:changed:staged",
    "pre-push": "node tools/runtime/run-npm.cjs run quality:logged -- pre-push"
  }
}

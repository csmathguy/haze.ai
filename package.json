{
  "name": "taxes",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.9.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/csmathguy/Taxes.git"
  },
  "bugs": {
    "url": "https://github.com/csmathguy/Taxes/issues"
  },
  "homepage": "https://github.com/csmathguy/Taxes#readme",
  "engines": {
    "node": ">=24.14.0",
    "npm": ">=11.6.4"
  },
  "workspaces": [
    "apps/*",
    "apps/*/*",
    "packages/*"
  ],
  "scripts": {
    "build:audit:web": "node tools/runtime/run-npm.cjs run build -w @taxes/audit-web",
    "build:code-review:web": "node tools/runtime/run-npm.cjs run build -w @taxes/code-review-web",
    "build:knowledge:web": "node tools/runtime/run-npm.cjs run build -w @taxes/knowledge-web",
    "build:plan:web": "node tools/runtime/run-npm.cjs run build -w @taxes/plan-web",
    "build:taxes:web": "node tools/runtime/run-npm.cjs run build -w @taxes/web",
    "build:web": "node tools/runtime/run-npm.cjs run build -w @taxes/web",
    "dev:audit:api": "node tools/runtime/run-npm.cjs run dev -w @taxes/audit-api",
    "dev:audit:web": "node tools/runtime/run-npm.cjs run dev -w @taxes/audit-web",
    "dev:code-review:api": "node tools/runtime/run-npm.cjs run dev -w @taxes/code-review-api",
    "dev:code-review:web": "node tools/runtime/run-npm.cjs run dev -w @taxes/code-review-web",
    "dev:knowledge:api": "node tools/runtime/run-npm.cjs run dev -w @taxes/knowledge-api",
    "dev:knowledge:web": "node tools/runtime/run-npm.cjs run dev -w @taxes/knowledge-web",
    "dev:env": "node ./node_modules/tsx/dist/cli.mjs tools/agent/dev-environment.ts start",
    "dev:env:list": "node ./node_modules/tsx/dist/cli.mjs tools/agent/dev-environment.ts list",
    "repo:refresh": "node ./node_modules/tsx/dist/cli.mjs tools/agent/refresh-workspace.ts",
    "dev:plan:api": "node tools/runtime/run-npm.cjs run dev -w @taxes/plan-api",
    "dev:plan:web": "node tools/runtime/run-npm.cjs run dev -w @taxes/plan-web",
    "dev:taxes:api": "node tools/runtime/run-npm.cjs run dev -w @taxes/api",
    "dev:api": "node tools/runtime/run-npm.cjs run dev -w @taxes/api",
    "dev:taxes:web": "node tools/runtime/run-npm.cjs run dev -w @taxes/web",
    "dev:web": "node tools/runtime/run-npm.cjs run dev -w @taxes/web",
    "knowledge:cli": "node ./node_modules/tsx/dist/cli.mjs tools/knowledge/knowledge-cli.ts",
    "plan:cli": "node ./node_modules/tsx/dist/cli.mjs tools/planning/plan-cli.ts",
    "plan:seed:mvp": "node tools/runtime/run-npm.cjs run plan:cli -- seed mvp",
    "prisma:check": "npm run prisma:validate && npm run prisma:generate",
    "prisma:generate": "node ./node_modules/tsx/dist/cli.mjs tools/database/generate-client.ts",
    "prisma:migrate:deploy": "node ./node_modules/tsx/dist/cli.mjs tools/database/apply-migrations.ts",
    "prisma:migrate:deploy:plan": "node ./node_modules/tsx/dist/cli.mjs tools/database/apply-plan-migrations.ts",
    "prisma:migrate:dev": "node ./node_modules/tsx/dist/cli.mjs tools/database/create-migration.ts",
    "prisma:studio": "prisma studio --schema prisma/schema.prisma",
    "pr:draft": "node ./node_modules/tsx/dist/cli.mjs tools/agent/pull-request-draft.ts",
    "pr:sync": "node ./node_modules/tsx/dist/cli.mjs tools/agent/pull-request-sync.ts",
    "prisma:validate": "prisma validate --schema prisma/schema.prisma",
    "postinstall": "npm run prisma:generate",
    "prepare": "simple-git-hooks",
    "lint": "eslint \"apps/taxes/api/src/**/*.ts\" \"apps/taxes/web/src/**/*.{ts,tsx}\" \"apps/taxes/web/vite.config.ts\" \"apps/plan/api/src/**/*.ts\" \"apps/plan/web/src/**/*.{ts,tsx}\" \"apps/plan/web/vite.config.ts\" \"apps/audit/api/src/**/*.ts\" \"apps/audit/web/src/**/*.{ts,tsx}\" \"apps/audit/web/vite.config.ts\" \"apps/code-review/api/src/**/*.ts\" \"apps/code-review/web/src/**/*.{ts,tsx}\" \"apps/code-review/web/vite.config.ts\" \"apps/knowledge/api/src/**/*.ts\" \"apps/knowledge/web/src/**/*.{ts,tsx}\" \"apps/knowledge/web/vite.config.ts\" packages/shared/src prisma.config.ts tools/agent tools/database tools/knowledge tools/planning tools/quality vitest.config.ts --max-warnings=0",
    "lint:fix": "eslint \"apps/taxes/api/src/**/*.ts\" \"apps/taxes/web/src/**/*.{ts,tsx}\" \"apps/taxes/web/vite.config.ts\" \"apps/plan/api/src/**/*.ts\" \"apps/plan/web/src/**/*.{ts,tsx}\" \"apps/plan/web/vite.config.ts\" \"apps/audit/api/src/**/*.ts\" \"apps/audit/web/src/**/*.{ts,tsx}\" \"apps/audit/web/vite.config.ts\" \"apps/code-review/api/src/**/*.ts\" \"apps/code-review/web/src/**/*.{ts,tsx}\" \"apps/code-review/web/vite.config.ts\" \"apps/knowledge/api/src/**/*.ts\" \"apps/knowledge/web/src/**/*.{ts,tsx}\" \"apps/knowledge/web/vite.config.ts\" packages/shared/src prisma.config.ts tools/agent tools/database tools/knowledge tools/planning tools/quality vitest.config.ts --fix",
    "stylelint": "stylelint \"apps/taxes/web/src/**/*.{css,scss}\" \"apps/plan/web/src/**/*.{css,scss}\" \"apps/audit/web/src/**/*.{css,scss}\" \"apps/code-review/web/src/**/*.{css,scss}\" \"apps/knowledge/web/src/**/*.{css,scss}\" --allow-empty-input",
    "stylelint:fix": "stylelint \"apps/taxes/web/src/**/*.{css,scss}\" \"apps/plan/web/src/**/*.{css,scss}\" \"apps/audit/web/src/**/*.{css,scss}\" \"apps/code-review/web/src/**/*.{css,scss}\" \"apps/knowledge/web/src/**/*.{css,scss}\" --fix --allow-empty-input",
    "typecheck": "npm run typecheck:shared && npm run typecheck:api && npm run typecheck:web && npm run typecheck:plan:api && npm run typecheck:plan:web && npm run typecheck:audit:api && npm run typecheck:audit:web && npm run typecheck:code-review:api && npm run typecheck:code-review:web && npm run typecheck:knowledge:api && npm run typecheck:knowledge:web && npm run typecheck:quality",
    "typecheck:api": "tsc --noEmit -p apps/taxes/api/tsconfig.json",
    "typecheck:audit:api": "tsc --noEmit -p apps/audit/api/tsconfig.json",
    "typecheck:audit:web": "tsc --noEmit -p apps/audit/web/tsconfig.json",
    "typecheck:code-review:api": "tsc --noEmit -p apps/code-review/api/tsconfig.json",
    "typecheck:code-review:web": "tsc --noEmit -p apps/code-review/web/tsconfig.json",
    "typecheck:knowledge:api": "tsc --noEmit -p apps/knowledge/api/tsconfig.json",
    "typecheck:knowledge:web": "tsc --noEmit -p apps/knowledge/web/tsconfig.json",
    "typecheck:plan:api": "tsc --noEmit -p apps/plan/api/tsconfig.json",
    "typecheck:plan:web": "tsc --noEmit -p apps/plan/web/tsconfig.json",
    "typecheck:shared": "tsc --noEmit -p packages/shared/tsconfig.json",
    "typecheck:web": "tsc --noEmit -p apps/taxes/web/tsconfig.json",
    "typecheck:quality": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:arch": "vitest run tools/quality/architecture",
    "quality": "npm run prisma:check && npm run typecheck && npm run lint && npm run stylelint && npm run test",
    "quality:changed": "node ./node_modules/tsx/dist/cli.mjs tools/agent/changed-quality.ts",
    "quality:changed:staged": "node ./node_modules/tsx/dist/cli.mjs tools/agent/changed-quality.ts --staged --workflow pre-commit",
    "quality:logged": "node ./node_modules/tsx/dist/cli.mjs tools/agent/quality-gates.ts",
    "quality:logged:coverage": "node ./node_modules/tsx/dist/cli.mjs tools/agent/quality-gates.ts --with-coverage",
    "agent:worktree:create": "node ./node_modules/tsx/dist/cli.mjs tools/agent/parallel-worktree.ts",
    "audit:artifact": "node ./node_modules/tsx/dist/cli.mjs tools/agent/audit-record.ts artifact",
    "audit:decision": "node ./node_modules/tsx/dist/cli.mjs tools/agent/audit-record.ts decision",
    "audit:failure": "node ./node_modules/tsx/dist/cli.mjs tools/agent/audit-record.ts failure",
    "audit:handoff": "node ./node_modules/tsx/dist/cli.mjs tools/agent/audit-record.ts handoff",
    "workflow:retro": "node ./node_modules/tsx/dist/cli.mjs tools/agent/retrospective.ts",
    "execution:start": "node ./node_modules/tsx/dist/cli.mjs tools/agent/execution-log.ts start",
    "execution:end": "node ./node_modules/tsx/dist/cli.mjs tools/agent/execution-log.ts end",
    "workflow:start": "node ./node_modules/tsx/dist/cli.mjs tools/agent/workflow-log.ts start",
    "workflow:note": "node ./node_modules/tsx/dist/cli.mjs tools/agent/workflow-log.ts note",
    "workflow:end": "node ./node_modules/tsx/dist/cli.mjs tools/agent/workflow-log.ts end"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.4.0",
    "@vitest/coverage-v8": "^4.0.18",
    "archunit": "^2.1.63",
    "dotenv": "^17.3.1",
    "eslint": "^10.0.3",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.0.2",
    "globals": "^17.4.0",
    "prisma": "^7.4.2",
    "simple-git-hooks": "^2.13.1",
    "stylelint": "^17.4.0",
    "stylelint-config-standard": "^40.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.0.18"
  },
  "simple-git-hooks": {
    "pre-commit": "node tools/runtime/run-npm.cjs run quality:changed:staged",
    "pre-push": "node tools/runtime/run-npm.cjs run quality:logged -- pre-push"
  }
}

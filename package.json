{
  "name": "taxes",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.9.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/csmathguy/Taxes.git"
  },
  "bugs": {
    "url": "https://github.com/csmathguy/Taxes/issues"
  },
  "homepage": "https://github.com/csmathguy/Taxes#readme",
  "engines": {
    "node": ">=24.14.0",
    "npm": ">=11.6.4"
  },
  "workspaces": [
    "apps/*",
    "apps/*/*",
    "packages/*"
  ],
  "scripts": {
    "build:audit:web": "node tools/runtime/run-npm.cjs run build -w @taxes/audit-web",
    "build:code-review:web": "node tools/runtime/run-npm.cjs run build -w @taxes/code-review-web",
    "build:knowledge:web": "node tools/runtime/run-npm.cjs run build -w @taxes/knowledge-web",
    "build:plan:web": "node tools/runtime/run-npm.cjs run build -w @taxes/plan-web",
    "build:workflow:web": "node tools/runtime/run-npm.cjs run build -w @taxes/workflow-web",
    "build:taxes:web": "node tools/runtime/run-npm.cjs run build -w @taxes/web",
    "build:web": "node tools/runtime/run-npm.cjs run build -w @taxes/web",
    "dev:audit:api": "node tools/runtime/run-npm.cjs run dev -w @taxes/audit-api",
    "dev:audit:web": "node tools/runtime/run-npm.cjs run dev -w @taxes/audit-web",
    "dev:code-review:api": "node tools/runtime/run-npm.cjs run dev -w @taxes/code-review-api",
    "dev:code-review:web": "node tools/runtime/run-npm.cjs run dev -w @taxes/code-review-web",
    "dev:knowledge:api": "node tools/runtime/run-npm.cjs run dev -w @taxes/knowledge-api",
    "dev:knowledge:web": "node tools/runtime/run-npm.cjs run dev -w @taxes/knowledge-web",
    "dev:env": "node ./node_modules/tsx/dist/cli.mjs tools/agent/dev-environment.ts start",
    "dev:env:list": "node ./node_modules/tsx/dist/cli.mjs tools/agent/dev-environment.ts list",
    "repo:refresh": "node ./node_modules/tsx/dist/cli.mjs tools/agent/refresh-workspace.ts",
    "dev:plan:api": "node tools/runtime/run-npm.cjs run dev -w @taxes/plan-api",
    "dev:plan:web": "node tools/runtime/run-npm.cjs run dev -w @taxes/plan-web",
    "dev:workflow:api": "node tools/runtime/run-npm.cjs run dev -w @taxes/workflow-api",
    "dev:workflow:web": "node tools/runtime/run-npm.cjs run dev -w @taxes/workflow-web",
    "gateway:restart": "node ./node_modules/tsx/dist/cli.mjs tools/agent/gateway-restart.ts",
    "dev:taxes:api": "node tools/runtime/run-npm.cjs run dev -w @taxes/api",
    "dev:gateway:api": "node tools/runtime/run-npm.cjs run dev -w @taxes/gateway-api",
    "dev:api": "node tools/runtime/run-npm.cjs run dev -w @taxes/gateway-api",
    "dev:taxes:web": "node tools/runtime/run-npm.cjs run dev -w @taxes/web",
    "dev:web": "node tools/runtime/run-npm.cjs run dev -w @taxes/web",
    "knowledge:cli": "node ./node_modules/tsx/dist/cli.mjs tools/knowledge/knowledge-cli.ts",
    "plan:cli": "node ./node_modules/tsx/dist/cli.mjs tools/planning/plan-cli.ts",
    "plan:seed:mvp": "node tools/runtime/run-npm.cjs run plan:cli -- seed mvp",
    "prisma:check": "npm run prisma:validate && npm run prisma:generate",
    "prisma:generate": "node ./node_modules/tsx/dist/cli.mjs tools/database/generate-client.ts",
    "prisma:migrate:deploy": "node ./node_modules/tsx/dist/cli.mjs tools/database/apply-migrations.ts",
    "prisma:migrate:deploy:plan": "node ./node_modules/tsx/dist/cli.mjs tools/database/apply-plan-migrations.ts",
    "prisma:migrate:dev": "node ./node_modules/tsx/dist/cli.mjs tools/database/create-migration.ts",
    "prisma:studio": "node ./node_modules/prisma/build/index.js studio --schema prisma/schema.prisma",
    "pr:draft": "node ./node_modules/tsx/dist/cli.mjs tools/agent/pull-request-draft.ts",
    "pr:sync": "node ./node_modules/tsx/dist/cli.mjs tools/agent/pull-request-sync.ts",
    "prisma:validate": "node ./node_modules/prisma/build/index.js validate --schema prisma/schema.prisma",
    "postinstall": "npm run prisma:generate",
    "prepare": "simple-git-hooks",
    "lint": "node ./node_modules/eslint/bin/eslint.js \"apps/taxes/api/src/**/*.ts\" \"apps/taxes/web/src/**/*.{ts,tsx}\" \"apps/taxes/web/vite.config.ts\" \"apps/plan/api/src/**/*.ts\" \"apps/plan/web/src/**/*.{ts,tsx}\" \"apps/plan/web/vite.config.ts\" \"apps/audit/api/src/**/*.ts\" \"apps/audit/web/src/**/*.{ts,tsx}\" \"apps/audit/web/vite.config.ts\" \"apps/code-review/api/src/**/*.ts\" \"apps/code-review/web/src/**/*.{ts,tsx}\" \"apps/code-review/web/vite.config.ts\" \"apps/knowledge/api/src/**/*.ts\" \"apps/knowledge/web/src/**/*.{ts,tsx}\" \"apps/knowledge/web/vite.config.ts\" \"apps/workflow/web/src/**/*.{ts,tsx}\" \"apps/workflow/web/vite.config.ts\" \"apps/gateway/api/src/**/*.ts\" packages/shared/src prisma.config.ts tools/agent tools/database tools/knowledge tools/planning tools/quality vitest.config.ts --max-warnings=0",
    "lint:fix": "node ./node_modules/eslint/bin/eslint.js \"apps/taxes/api/src/**/*.ts\" \"apps/taxes/web/src/**/*.{ts,tsx}\" \"apps/taxes/web/vite.config.ts\" \"apps/plan/api/src/**/*.ts\" \"apps/plan/web/src/**/*.{ts,tsx}\" \"apps/plan/web/vite.config.ts\" \"apps/audit/api/src/**/*.ts\" \"apps/audit/web/src/**/*.{ts,tsx}\" \"apps/audit/web/vite.config.ts\" \"apps/code-review/api/src/**/*.ts\" \"apps/code-review/web/src/**/*.{ts,tsx}\" \"apps/code-review/web/vite.config.ts\" \"apps/knowledge/api/src/**/*.ts\" \"apps/knowledge/web/src/**/*.{ts,tsx}\" \"apps/knowledge/web/vite.config.ts\" \"apps/workflow/web/src/**/*.{ts,tsx}\" \"apps/workflow/web/vite.config.ts\" \"apps/gateway/api/src/**/*.ts\" packages/shared/src prisma.config.ts tools/agent tools/database tools/knowledge tools/planning tools/quality vitest.config.ts --fix",
    "stylelint": "node ./node_modules/stylelint/bin/stylelint.mjs \"apps/taxes/web/src/**/*.{css,scss}\" \"apps/plan/web/src/**/*.{css,scss}\" \"apps/audit/web/src/**/*.{css,scss}\" \"apps/code-review/web/src/**/*.{css,scss}\" \"apps/knowledge/web/src/**/*.{css,scss}\" --allow-empty-input",
    "stylelint:fix": "node ./node_modules/stylelint/bin/stylelint.mjs \"apps/taxes/web/src/**/*.{css,scss}\" \"apps/plan/web/src/**/*.{css,scss}\" \"apps/audit/web/src/**/*.{css,scss}\" \"apps/code-review/web/src/**/*.{css,scss}\" \"apps/knowledge/web/src/**/*.{css,scss}\" --fix --allow-empty-input",
    "typecheck": "npm run typecheck:shared && npm run typecheck:api && npm run typecheck:web && npm run typecheck:plan:api && npm run typecheck:plan:web && npm run typecheck:audit:api && npm run typecheck:audit:web && npm run typecheck:code-review:api && npm run typecheck:code-review:web && npm run typecheck:knowledge:api && npm run typecheck:knowledge:web && npm run typecheck:workflow:web && npm run typecheck:gateway:api && npm run typecheck:quality",
    "typecheck:gateway:api": "node ./node_modules/typescript/bin/tsc --noEmit -p apps/gateway/api/tsconfig.json",
    "typecheck:api": "node ./node_modules/typescript/bin/tsc --noEmit -p apps/taxes/api/tsconfig.json",
    "typecheck:audit:api": "node ./node_modules/typescript/bin/tsc --noEmit -p apps/audit/api/tsconfig.json",
    "typecheck:audit:web": "node ./node_modules/typescript/bin/tsc --noEmit -p apps/audit/web/tsconfig.json",
    "typecheck:code-review:api": "node ./node_modules/typescript/bin/tsc --noEmit -p apps/code-review/api/tsconfig.json",
    "typecheck:code-review:web": "node ./node_modules/typescript/bin/tsc --noEmit -p apps/code-review/web/tsconfig.json",
    "typecheck:knowledge:api": "node ./node_modules/typescript/bin/tsc --noEmit -p apps/knowledge/api/tsconfig.json",
    "typecheck:knowledge:web": "node ./node_modules/typescript/bin/tsc --noEmit -p apps/knowledge/web/tsconfig.json",
    "typecheck:plan:api": "node ./node_modules/typescript/bin/tsc --noEmit -p apps/plan/api/tsconfig.json",
    "typecheck:plan:web": "node ./node_modules/typescript/bin/tsc --noEmit -p apps/plan/web/tsconfig.json",
    "typecheck:workflow:web": "node ./node_modules/typescript/bin/tsc --noEmit -p apps/workflow/web/tsconfig.json",
    "typecheck:shared": "node ./node_modules/typescript/bin/tsc --noEmit -p packages/shared/tsconfig.json",
    "typecheck:web": "node ./node_modules/typescript/bin/tsc --noEmit -p apps/taxes/web/tsconfig.json",
    "typecheck:quality": "node ./node_modules/typescript/bin/tsc --noEmit -p tsconfig.json",
    "test": "node ./node_modules/vitest/vitest.mjs run",
    "test:watch": "node ./node_modules/vitest/vitest.mjs",
    "test:coverage": "node ./node_modules/vitest/vitest.mjs run --coverage",
    "test:arch": "node ./node_modules/vitest/vitest.mjs run tools/quality/architecture",
    "quality": "npm run prisma:check && npm run typecheck && npm run lint && npm run stylelint && npm run test",
    "quality:lint-only": "node ./node_modules/tsx/dist/cli.mjs tools/agent/lint-only.ts",
    "quality:changed": "node ./node_modules/tsx/dist/cli.mjs tools/agent/changed-quality.ts",
    "quality:changed:staged": "node ./node_modules/tsx/dist/cli.mjs tools/agent/changed-quality.ts --staged --workflow pre-commit",
    "quality:logged": "node ./node_modules/tsx/dist/cli.mjs tools/agent/quality-gates.ts",
    "quality:logged:coverage": "node ./node_modules/tsx/dist/cli.mjs tools/agent/quality-gates.ts --with-coverage",
    "agent:discover-files": "node ./node_modules/tsx/dist/cli.mjs tools/agent/file-discovery.ts",
    "agent:heartbeat": "node ./node_modules/tsx/dist/cli.mjs tools/agent/heartbeat.ts",
    "agent:worktree:create": "node ./node_modules/tsx/dist/cli.mjs tools/agent/parallel-worktree.ts",
    "agent:worktree:prune": "node ./node_modules/tsx/dist/cli.mjs tools/agent/worktree-prune.ts",
    "worktree:ensure-junction": "node ./node_modules/tsx/dist/cli.mjs tools/agent/worktree-ensure-junction.ts",
    "repo:health": "node ./node_modules/tsx/dist/cli.mjs tools/agent/repo-health.ts",
    "db:check-migrations": "node ./node_modules/tsx/dist/cli.mjs tools/agent/check-migrations.ts",
    "quality:preflight": "npm run typecheck && npm run lint",
    "audit:progress": "node ./node_modules/tsx/dist/cli.mjs tools/agent/audit-progress.ts",
    "audit:transcript:view": "node ./node_modules/tsx/dist/cli.mjs tools/agent/audit-transcript.ts",
    "audit:artifact": "node ./node_modules/tsx/dist/cli.mjs tools/agent/audit-record.ts artifact",
    "audit:decision": "node ./node_modules/tsx/dist/cli.mjs tools/agent/audit-record.ts decision",
    "audit:failure": "node ./node_modules/tsx/dist/cli.mjs tools/agent/audit-record.ts failure",
    "audit:handoff": "node ./node_modules/tsx/dist/cli.mjs tools/agent/audit-record.ts handoff",
    "workflow:retro": "node ./node_modules/tsx/dist/cli.mjs tools/agent/retrospective.ts",
    "execution:start": "node ./node_modules/tsx/dist/cli.mjs tools/agent/execution-log.ts start",
    "execution:end": "node ./node_modules/tsx/dist/cli.mjs tools/agent/execution-log.ts end",
    "workflow:start": "node ./node_modules/tsx/dist/cli.mjs tools/agent/workflow-log.ts start",
    "workflow:note": "node ./node_modules/tsx/dist/cli.mjs tools/agent/workflow-log.ts note",
    "workflow:end": "node ./node_modules/tsx/dist/cli.mjs tools/agent/workflow-log.ts end",
    "workflow:run": "node ./node_modules/tsx/dist/cli.mjs tools/workflow/workflow-run.ts",
    "workflow:run:start": "node tools/workflow/start-workflow-run.cjs",
    "workflow:token-report": "node ./node_modules/tsx/dist/cli.mjs tools/agent/workflow-token-report.ts",
    "workflow:watch": "node ./node_modules/tsx/dist/cli.mjs tools/agent/workflow-watch.ts"
  },
  "devDependencies": {
    "@cacheable/memory": "^2.0.8",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.0.18",
    "archunit": "^2.1.63",
    "dotenv": "^17.3.1",
    "eslint": "^10.0.3",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.0.2",
    "globals": "^17.4.0",
    "prisma": "^7.5.0",
    "simple-git-hooks": "^2.13.1",
    "stylelint": "^17.4.0",
    "stylelint-config-standard": "^40.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.0.18"
  },
  "simple-git-hooks": {
    "pre-commit": "node tools/runtime/pre-commit.cjs",
    "pre-push": "node -e \"process.stdout.write('[pre-push] Skipping local gate; GitHub Actions and workflow webhooks will validate after push.\\n')\""
  },
  "dependencies": {
    "mermaid": "^11.13.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "optionalDependencies": {
    "@esbuild/win32-x64": "^0.27.4"
  }
}
